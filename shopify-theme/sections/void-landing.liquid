      "label": "Hero Background Image",
      "info": "Used as fallback when no video is set."
    },
    {
      "type": "header",
      "content": "CTA Buttons"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary CTA Label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA URL"
    },
    {
      "type": "text",
      "id": "cta_ghost_label",
      "label": "Ghost CTA Label",
      "default": "Enter Atelier"
    },
    {
      "type": "url",
      "id": "cta_ghost_url",
      "label": "Ghost CTA URL"
    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "text",
      "id": "collection_label",
      "label": "Collection eyebrow",
      "default": "SS 2040 — Primary Line"
    },
    {
      "type": "textarea",
      "id": "collection_heading",
      "label": "Collection heading",
      "default": "Where darkness meets form"
    },
