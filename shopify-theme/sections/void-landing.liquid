      "info": "First 3 products will be shown. Leave empty to show placeholder cards."
    },
    {
      "type": "header",
      "content": "Philosophy / Stats"
    },
    {
      "type": "textarea",
      "id": "philosophy_text",
      "label": "Philosophy statement",
      "default": "Clothing is not fabric. It is architecture for the body, silence made tangible."
    },
    {
      "type": "number",
      "id": "stat1_value",
      "label": "Stat 1 — Number",
      "default": 97
    },
    {
      "type": "text",
      "id": "stat1_label",
      "label": "Stat 1 — Label",
      "default": "Artisan Crafted"
    },
    {
      "type": "number",
      "id": "stat2_value",
      "label": "Stat 2 — Number",
      "default": 12
    },
    {
      "type": "text",
      "id": "stat2_label",
      "label": "Stat 2 — Label",
      "default": "Collections"
    },
    {
      "type": "number",
      "id": "stat3_value",
      "label": "Stat 3 — Number",
      "default": 48
    },
    {
      "type": "text",
      "id": "stat3_label",
      "label": "Stat 3 — Label",
      "default": "Countries"
    },
    {
      "type": "header",
      "content": "Feature Block"
    },
    {
      "type": "text",
      "id": "feature_label",
      "label": "Feature eyebrow",
      "default": "Material Innovation"
    },
    {
      "type": "text",
      "id": "feature_heading",
      "label": "Feature heading",
      "default": "Fabric from the future"
    },
    {
      "type": "textarea",
      "id": "feature_body",
      "label": "Feature body text",
      "default": "Each garment is constructed using thermally-responsive nano-fibers woven by robotic artisans in our Tokyo atelier. The material reacts to your body temperature, shifting weight and texture throughout the day. This is clothing that breathes with you."
    }
  ],
  "presets": [
    {
      "name": "VØID Landing Page",
